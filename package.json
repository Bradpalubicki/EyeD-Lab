{
  "name": "eyed",
  "version": "0.0.1",
  "private": true,
  "description": "Patient-owned medical records platform",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "vitest run --workspace vitest.workspace.ts",
    "test:watch": "vitest --workspace vitest.workspace.ts",
    "test:coverage": "vitest run --workspace vitest.workspace.ts --coverage",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eyed/tsconfig": "workspace:*",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "lint-staged": {
    "*.{ts,tsx,mts}": [
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "overrides": {
      "serialize-javascript": "^7.0.3",
      "bn.js": "^4.12.3",
      "lodash": "^4.17.23",
      "undici": "^6.23.0",
      "tmp": "^0.2.4",
      "cookie": "^0.7.0"
    }
  }
}
