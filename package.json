{
  "name": "eyed",
  "version": "0.0.1",
  "private": true,
  "description": "Patient-owned medical records platform",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@eyed/tsconfig": "workspace:*",
    "turbo": "^2.3.0",
    "prettier": "^3.4.0"
  },
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "serialize-javascript": ">=7.0.3",
      "bn.js": ">=4.12.3",
      "lodash": ">=4.17.23",
      "undici": ">=6.23.0",
      "tmp": ">=0.2.4",
      "cookie": ">=0.7.0"
    }
  }
}
