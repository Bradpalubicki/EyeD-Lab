# EyeD Environment Variables
# Copy to .env and fill in values

# Database (Phase 1)
DATABASE_URL=postgres://eyed:password@localhost:5432/eyed

# Redis (Phase 1)
REDIS_URL=redis://localhost:6379

# JWT Secret (Phase 1)
JWT_SECRET=change-me-in-production

# Blockchain RPC (Phase 2)
LINEA_SEPOLIA_RPC_URL=https://rpc.sepolia.linea.build
LINEA_RPC_URL=https://rpc.linea.build
DEPLOYER_PRIVATE_KEY=

# IPFS (Phase 2)
PINATA_API_KEY=
PINATA_SECRET_KEY=

# Notifications (Phase 1)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
SENDGRID_API_KEY=

# Expo Push (Phase 1)
EXPO_PUSH_TOKEN=
